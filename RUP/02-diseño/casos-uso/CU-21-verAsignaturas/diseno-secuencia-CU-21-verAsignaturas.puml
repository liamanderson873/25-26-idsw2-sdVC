@startuml secuencia-cu21-ver-asignaturas
title Diagrama de Secuencia - Ver Asignaturas

actor "Docente" as Actor
participant "Frontend\n(React)" as FE
participant "ControladorAsignatura" as Controller
participant "ServicioAsignatura" as Service
participant "RepositorioAsignatura" as RepoAsig
database "Base de Datos\n(PostgreSQL)" as DB

Actor -> FE : Navega a "Asignaturas"
activate FE

FE -> Controller : GET /api/asignaturas
activate Controller

Controller -> Service : listarTodos()
activate Service

Service -> RepoAsig : findAll()
activate RepoAsig
RepoAsig -> DB : SELECT * FROM asignaturas
DB --> RepoAsig : lista de asignaturas
RepoAsig --> Service : List<Asignatura>
deactivate RepoAsig

Service --> Controller : List<DTO_Asignatura>
deactivate Service

Controller --> FE : 200 OK (JSON lista)
deactivate Controller

FE --> Actor : Muestra tabla de asignaturas
deactivate FE

@enduml
