@startuml secuencia-cu08-exportar-preguntas
title Diagrama de Secuencia - Exportar Preguntas

actor "Docente" as Actor
participant "Frontend\n(React)" as FE
participant "ControladorPregunta" as Controller
participant "ServicioPregunta" as Service
participant "RepositorioPregunta" as RepoPreg
database "Base de Datos\n(PostgreSQL)" as DB

Actor -> FE : Pulsa "Exportar Preguntas"
activate FE

FE -> Controller : GET /api/preguntas
activate Controller

Controller -> Service : listarTodas()
activate Service

Service -> RepoPreg : findAll()
activate RepoPreg
RepoPreg -> DB : SELECT * FROM preguntas JOIN respuestas
DB --> RepoPreg : lista_preguntas_con_respuestas
RepoPreg --> Service : List<Pregunta>
deactivate RepoPreg

Service --> Controller : List<DTO_Pregunta>
deactivate Service

Controller --> FE : 200 OK (JSON lista)
deactivate Controller

FE -> FE : Serializa JSON y genera descarga
FE --> Actor : Descarga fichero JSON de preguntas
deactivate FE

@enduml
