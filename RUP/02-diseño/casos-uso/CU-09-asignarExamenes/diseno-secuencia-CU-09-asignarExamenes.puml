@startuml secuencia-cu09-asignar-examen
title Diagrama de Secuencia - Asignar Exámenes

actor "Docente" as Actor
participant "Frontend\n(React)" as FE
participant "ControladorExamen" as Controller
participant "ServicioExamen" as Service
participant "RepositorioExamen" as RepoExamen
participant "RepositorioAlumno" as RepoAlumno
participant "RepositorioExamenAlumno" as RepoExAl
database "Base de Datos\n(PostgreSQL)" as DB

Actor -> FE : Selecciona examen y alumnos
activate FE

FE -> Controller : POST /api/examenes/asignar (DTO_AsignarExamen)
activate Controller

Controller -> Service : asignarExamenAAlumnos(examenId, alumnoIds)
activate Service

Service -> RepoExamen : findById(examenId)
activate RepoExamen
RepoExamen -> DB : SELECT examen
DB --> RepoExamen : examen
RepoExamen --> Service : examen
deactivate RepoExamen

loop por cada alumnoId
    Service -> RepoAlumno : findById(alumnoId)
    activate RepoAlumno
    RepoAlumno -> DB : SELECT alumno
    DB --> RepoAlumno : alumno
    RepoAlumno --> Service : alumno
    deactivate RepoAlumno

    Service -> Service : generarClaveCorreccion(alumno, examen)
    note right: SHA-256(DNI + ID_Examen + Salt)

    Service -> RepoExAl : save(ejemplar)
    activate RepoExAl
    RepoExAl -> DB : INSERT examen_alumno
    DB --> RepoExAl : ok
    RepoExAl --> Service : ejemplarGuardado
    deactivate RepoExAl
end

Service --> Controller : void
deactivate Service

Controller --> FE : 200 OK (Asignado correctamente)
deactivate Controller

FE --> Actor : Muestra lista de ejemplares asignados
deactivate FE

@enduml
