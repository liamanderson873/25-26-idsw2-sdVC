@startuml cu12-editarAsignatura-analisis-secuencia
title Diagrama de Secuencia (Análisis) - CU-12: Editar Asignatura

actor "Docente" as Actor
participant ":VistaEdicionAsignatura" as Boundary <<boundary>>
participant ":ControladorAsignaturas" as Control <<control>>
participant ":Asignatura" as Entity <<entity>>

Actor -> Boundary : seleccionarAsignatura(id)
activate Boundary

Boundary -> Control : obtenerAsignatura(id)
activate Control

Control -> Entity : buscar(id)
activate Entity
Entity --> Control : asignatura
deactivate Entity

Control --> Boundary : datosAsignatura
deactivate Control

Actor -> Boundary : modificarDatos(datos)

Boundary -> Control : actualizarAsignatura(id, datos)
activate Control

Control -> Entity : actualizar(datos)
activate Entity
Entity --> Control : ok
deactivate Entity

Control --> Boundary : confirmacion
deactivate Control

Boundary --> Actor : mostrarConfirmacion()
deactivate Boundary

@enduml
