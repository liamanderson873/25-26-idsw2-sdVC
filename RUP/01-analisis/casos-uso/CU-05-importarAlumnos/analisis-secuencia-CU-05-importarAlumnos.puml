@startuml cu05-importarAlumnos-analisis-secuencia
title Diagrama de Secuencia (Análisis) - CU-05: Importar Alumnos

actor "Docente" as Actor
participant ":StudentImportView" as Boundary <<boundary>>
participant ":StudentImportController" as Control <<control>>
participant ":Student" as Entity <<entity>>

Actor -> Boundary : subirFichero(ficheroJSON)
activate Boundary

Boundary -> Control : importarAlumnos(listaAlumnos)
activate Control

Control -> Entity : validarDatos(alumno)
activate Entity
Entity --> Control : ok
deactivate Entity

Control -> Entity : guardarOActualizar(alumno)
activate Entity
Entity --> Control : alumno
deactivate Entity

Control --> Boundary : confirmacion
deactivate Control

Boundary --> Actor : mostrarConfirmacion()
deactivate Boundary

@enduml
