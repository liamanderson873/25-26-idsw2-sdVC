@startuml cu23-verAlumnos-analisis-secuencia
title Diagrama de Secuencia (Análisis) - CU-23: Ver Alumnos

actor "Docente" as Actor
participant ":VistaListaAlumnos" as Boundary <<boundary>>
participant ":VistaDetalleAlumno" as DetailBoundary <<boundary>>
participant ":ControladorAlumnos" as ControlAlumnos <<control>>
participant ":ControladorExamen" as ControlExamen <<control>>
participant ":Alumno" as EntityAlumno <<entity>>
participant ":ExamenAlumno" as EntityExamen <<entity>>

group Flujo 1: Listar alumnos
    Actor -> Boundary : solicitarListado()
    activate Boundary

    Boundary -> ControlAlumnos : obtenerAlumnos()
    activate ControlAlumnos

    ControlAlumnos -> EntityAlumno : consultarTodos()
    activate EntityAlumno
    EntityAlumno --> ControlAlumnos : listaAlumnos
    deactivate EntityAlumno

    ControlAlumnos --> Boundary : listaAlumnos
    deactivate ControlAlumnos

    Boundary --> Actor : mostrarListado(alumnos)
    deactivate Boundary
end

group Flujo 2: Ver detalle del alumno
    Actor -> Boundary : seleccionarAlumno(id)
    activate Boundary

    Boundary -> DetailBoundary : navegarADetalle(id)
    activate DetailBoundary

    DetailBoundary -> ControlExamen : obtenerExamenesAlumno(alumnoId)
    activate ControlExamen

    ControlExamen -> EntityExamen : findByAlumnoId(alumnoId)
    activate EntityExamen
    EntityExamen --> ControlExamen : listaEjemplares
    deactivate EntityExamen

    ControlExamen --> DetailBoundary : listaEjemplares
    deactivate ControlExamen

    DetailBoundary --> Actor : mostrarDetalle(alumno, examenes)
    deactivate DetailBoundary
    deactivate Boundary
end

@enduml
