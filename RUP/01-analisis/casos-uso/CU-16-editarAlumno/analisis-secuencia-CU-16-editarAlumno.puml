@startuml cu16-editarAlumno-analisis-secuencia
title Diagrama de Secuencia (Análisis) - CU-16: Editar Alumno

actor "Docente" as Actor
participant ":StudentEditView" as Boundary <<boundary>>
participant ":StudentController" as Control <<control>>
participant ":Student" as Entity <<entity>>

Actor -> Boundary : seleccionarAlumno(id)
activate Boundary

Boundary -> Control : obtenerAlumno(id)
activate Control

Control -> Entity : buscar(id)
activate Entity
Entity --> Control : alumno
deactivate Entity

Control --> Boundary : datosAlumno
deactivate Control

Actor -> Boundary : modificarDatos(datos)

Boundary -> Control : actualizarAlumno(id, datos)
activate Control

Control -> Entity : actualizar(datos)
activate Entity
Entity --> Control : ok
deactivate Entity

Control --> Boundary : confirmacion
deactivate Control

Boundary --> Actor : mostrarConfirmacion()
deactivate Boundary

@enduml
