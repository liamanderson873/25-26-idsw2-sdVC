@startuml cu09-asignarExamenes-analisis-secuencia
title Diagrama de Secuencia (Análisis) - CU-09: Asignar Exámenes

actor "Docente" as Actor
participant ":VistaAsignacionExamen" as Boundary <<boundary>>
participant ":ControladorAsignacion" as Control <<control>>
participant ":Examen" as Entity <<entity>>

Actor -> Boundary : configurarAsignacion(examen, alumnos)
activate Boundary

Boundary -> Control : asignarExamenes(examenId, listaAlumnos)
activate Control

Control -> Entity : obtenerExamen(examenId)
activate Entity
Entity --> Control : examen
deactivate Entity

Control -> Entity : asignarAlumno(alumno)
activate Entity
Entity --> Control : ok
deactivate Entity

Control -> Entity : guardar(examen)
activate Entity
Entity --> Control : ok
deactivate Entity

Control --> Boundary : resumenAsignacion
deactivate Control

Boundary --> Actor : mostrarResumen(resumen)
deactivate Boundary

@enduml
