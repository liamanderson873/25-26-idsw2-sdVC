@startuml cu13-crearDocente-analisis-secuencia
title Diagrama de Secuencia (Análisis) - CU-13: Crear Docente

actor "AdministradorInstitucional" as Actor
participant ":DocenteCreationView" as Boundary <<boundary>>
participant ":DocenteController" as Control <<control>>
participant ":Docente" as Entity <<entity>>

Actor -> Boundary : introducirDatos(dni, nombre, apellidos, usuario, email, password)
activate Boundary

Boundary -> Control : crearDocente(datos)
activate Control

Control -> Entity : validarNoDuplicado(dni, usuario)
activate Entity
Entity --> Control : ok
deactivate Entity

Control -> Entity : inicializar(datos)
activate Entity
Entity --> Control : docente
deactivate Entity

Control -> Entity : guardar(docente)
activate Entity
Entity --> Control : ok
deactivate Entity

Control --> Boundary : confirmacion
deactivate Control

Boundary --> Actor : mostrarConfirmacion()
deactivate Boundary

@enduml
