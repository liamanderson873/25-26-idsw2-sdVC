@startuml cu21-verAsignaturas-analisis-secuencia
title Diagrama de Secuencia (Análisis) - CU-21: Ver Asignaturas

actor "Docente" as Actor
participant ":VistaListaAsignaturas" as Boundary <<boundary>>
participant ":VistaDetalleAsignatura" as DetailBoundary <<boundary>>
participant ":ControladorAsignaturas" as Control <<control>>
participant ":Asignatura" as Entity <<entity>>

group Flujo 1: Listar asignaturas
    Actor -> Boundary : solicitarListado()
    activate Boundary

    Boundary -> Control : obtenerAsignaturas()
    activate Control

    Control -> Entity : consultarTodas()
    activate Entity
    Entity --> Control : listaAsignaturas
    deactivate Entity

    Control --> Boundary : listaAsignaturas
    deactivate Control

    Boundary --> Actor : mostrarListado(asignaturas)
    deactivate Boundary
end

group Flujo 2: Ver detalle de asignatura
    Actor -> Boundary : seleccionarAsignatura(id)
    activate Boundary

    Boundary -> DetailBoundary : navegarADetalle(id)
    activate DetailBoundary
    note over DetailBoundary : Usa datos cacheados del Flujo 1.\nMuestra 3 acciones: Corregir,\nGenerar y Batería de Preguntas.

    DetailBoundary --> Actor : mostrarDetalle(asignatura)
    deactivate DetailBoundary
    deactivate Boundary
end

@enduml
