@startuml cu42-verExamen-analisis-secuencia
title Diagrama de Secuencia (Análisis) - CU-42: Ver Examen

actor "Docente" as Actor
participant ":VistaDetalleAlumno" as AlumnoBoundary <<boundary>>
participant ":ExamenRevisionPage" as Boundary <<boundary>>
participant ":ControladorExamen" as Control <<control>>
participant ":ExamenAlumno" as Entity <<entity>>

note over AlumnoBoundary, Boundary : ExamenRevisionPage se abre en una nueva pestaña del navegador\nmediante window.open('/examenes/revision/{id}', '_blank')

Actor -> AlumnoBoundary : seleccionarVerExamen(ejemplarId)
activate AlumnoBoundary

AlumnoBoundary -> Boundary : abrirNuevaPestana(ejemplarId)
activate Boundary

Boundary -> Control : obtenerRevision(ejemplarId)
activate Control

Control -> Entity : findById(id)
activate Entity
Entity --> Control : examen
deactivate Entity

Control --> Boundary : datosRevision
deactivate Control

Boundary --> Actor : mostrarExamen(datos)
deactivate Boundary
deactivate AlumnoBoundary

@enduml
