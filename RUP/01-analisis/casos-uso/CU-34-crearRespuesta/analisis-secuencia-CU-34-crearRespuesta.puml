@startuml cu34-crearRespuesta-analisis-secuencia
title Diagrama de Secuencia (Análisis) - CU-34: Crear Respuesta

actor "Docente" as Actor
participant ":AnswerCreationView" as Boundary <<boundary>>
participant ":AnswerCreationController" as Control <<control>>
participant ":Answer" as Entity <<entity>>

Actor -> Boundary : introducirDatos(texto, esCorrecta, preguntaId)
activate Boundary

Boundary -> Control : crearRespuesta(datos)
activate Control

Control -> Entity : validarPregunta(preguntaId)
activate Entity
Entity --> Control : pregunta
deactivate Entity

Control -> Entity : inicializar(texto, esCorrecta, pregunta)
activate Entity
Entity --> Control : respuesta
deactivate Entity

Control -> Entity : guardar(respuesta)
activate Entity
Entity --> Control : ok
deactivate Entity

Control --> Boundary : confirmacion
deactivate Control

Boundary --> Actor : mostrarConfirmacion()
deactivate Boundary

@enduml
