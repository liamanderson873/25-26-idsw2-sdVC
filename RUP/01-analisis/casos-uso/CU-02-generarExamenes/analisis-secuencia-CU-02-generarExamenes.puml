@startuml cu02-generarExamenes-analisis-secuencia
title Diagrama de Secuencia (Análisis) - CU-02: Generar Exámenes

actor "Docente" as Actor
participant ":ExamGenerationView" as Boundary <<boundary>>
participant ":ExamGenerationController" as Control <<control>>
participant ":Exam" as Entity <<entity>>

Actor -> Boundary : configurarGeneracion(parametros)
activate Boundary

Boundary -> Control : generarExamenes(parametros)
activate Control

Control -> Entity : seleccionarPreguntas(asignatura, temas, dificultad)
activate Entity
Entity --> Control : preguntasSeleccionadas
deactivate Entity

Control -> Entity : crearExamen(preguntas, alumno)
activate Entity
Entity --> Control : examen
deactivate Entity

Control -> Entity : guardar(examen)
activate Entity
Entity --> Control : ok
deactivate Entity

Control --> Boundary : informeGeneracion
deactivate Control

Boundary --> Actor : mostrarInforme(informe)
deactivate Boundary

@enduml
