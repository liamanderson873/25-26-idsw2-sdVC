@startuml cu03-importarConfiguracionGlobal-analisis-secuencia
title Diagrama de Secuencia (Análisis) - CU-03: Importar Configuración Global

actor "Docente" as Actor
participant ":VistaImportConfigGlobal" as Boundary <<boundary>>
participant ":ControladorImportacion" as Control <<control>>
participant ":ConfiguracionGlobal" as Entity <<entity>>

Actor -> Boundary : subirFichero(ficheroJSON)
activate Boundary

Boundary -> Control : importarConfiguracion(datos)
activate Control

Control -> Entity : validarEstructura(datos)
activate Entity
Entity --> Control : ok
deactivate Entity

Control -> Entity : importarAlumnos(listaAlumnos)
activate Entity
Entity --> Control : ok
deactivate Entity

Control -> Entity : importarGrados(listaGrados)
activate Entity
Entity --> Control : ok
deactivate Entity

Control -> Entity : importarAsignaturas(listaAsignaturas)
activate Entity
Entity --> Control : ok
deactivate Entity

Control -> Entity : importarPreguntas(listaPreguntas)
activate Entity
Entity --> Control : ok
deactivate Entity

Control --> Boundary : confirmacion
deactivate Control

Boundary --> Actor : mostrarConfirmacion()
deactivate Boundary

@enduml
