@startuml cu32-completarGestion-analisis-secuencia
title Diagrama de Secuencia (Análisis) - CU-32: Completar Gestión

actor "Usuario" as Actor
participant ":VistaGestion" as Boundary <<boundary>>
participant ":ControladorGestion" as Control <<control>>
participant ":EstadoSistema" as Entity <<entity>>

Actor -> Boundary : accederPanel()
activate Boundary

Boundary -> Control : obtenerEstadoSistema()
activate Control

Control -> Entity : consultarEstado()
activate Entity
Entity --> Control : estadoSistema
deactivate Entity

Control --> Boundary : panelDatos
deactivate Control

Actor -> Boundary : realizarAccionGestion(accion)

Boundary -> Control : procesarAccion(accion)
activate Control

Control -> Entity : actualizarEstado(accion)
activate Entity
Entity --> Control : ok
deactivate Entity

Control --> Boundary : resultadoAccion
deactivate Control

Boundary --> Actor : mostrarResultado(resultado)
deactivate Boundary

@enduml
