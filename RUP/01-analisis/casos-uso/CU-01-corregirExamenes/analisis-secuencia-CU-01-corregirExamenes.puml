@startuml cu01-corregirExamenes-analisis-secuencia
title Diagrama de Secuencia (Análisis) - CU-01: Corregir Exámenes

actor "Docente" as Actor
participant ":VistaCorreccion" as Boundary <<boundary>>
participant ":ControladorCorreccion" as Control <<control>>
participant ":Examen" as Entity <<entity>>

Actor -> Boundary : solicitarCorreccion(datos)
activate Boundary

Boundary -> Control : procesarCorreccion(datos)
activate Control

Control -> Entity : obtenerExamen(id)
activate Entity
Entity --> Control : exam
deactivate Entity

Control -> Entity : calcularPuntuacion(respuestas)
activate Entity
Entity --> Control : puntuacion
deactivate Entity

Control -> Entity : actualizarEstado(CORRECTED, puntuacion)
activate Entity
Entity --> Control : ok
deactivate Entity

Control --> Boundary : resumenCorreccion
deactivate Control

Boundary --> Actor : mostrarResultado(resumen)
deactivate Boundary

@enduml
