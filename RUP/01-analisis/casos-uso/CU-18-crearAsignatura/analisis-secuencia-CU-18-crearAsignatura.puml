@startuml cu18-crearAsignatura-analisis-secuencia
title Diagrama de Secuencia (Análisis) - CU-18: Crear Asignatura

actor "Docente" as Actor
participant ":SubjectCreationView" as Boundary <<boundary>>
participant ":SubjectController" as Control <<control>>
participant ":Subject" as Entity <<entity>>

Actor -> Boundary : introducirDatos(codigo, nombre, docente)
activate Boundary

Boundary -> Control : crearAsignatura(datos)
activate Control

Control -> Entity : validarNoDuplicado(codigo)
activate Entity
Entity --> Control : ok
deactivate Entity

Control -> Entity : inicializar(datos)
activate Entity
Entity --> Control : asignatura
deactivate Entity

Control -> Entity : guardar(asignatura)
activate Entity
Entity --> Control : ok
deactivate Entity

Control --> Boundary : confirmacion
deactivate Control

Boundary --> Actor : mostrarConfirmacion()
deactivate Boundary

@enduml
