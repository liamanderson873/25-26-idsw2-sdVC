@startuml secuencia-cu12-editar-asignatura
title Diagrama de Secuencia - Editar Asignatura

actor "Docente" as Actor
participant "Frontend\n(React)" as FE
participant "ControladorAsignatura" as Controller
participant "ServicioAsignatura" as Service
participant "RepositorioProfesor" as RepoProfesor
participant "RepositorioAsignatura" as RepoAsig
database "Base de Datos\n(PostgreSQL)" as DB

Actor -> FE : Modifica datos de la asignatura
activate FE

FE -> Controller : POST /api/asignaturas (DTO_Asignatura con código existente)
activate Controller

Controller -> Service : crearOActualizar(dto)
activate Service

Service -> RepoProfesor : findByDni(dniProfesor)
activate RepoProfesor
RepoProfesor -> DB : SELECT profesor
DB --> RepoProfesor : resultado
RepoProfesor --> Service : Optional<Profesor>
deactivate RepoProfesor

Service -> RepoAsig : findByCodigo(codigo)
activate RepoAsig
RepoAsig -> DB : SELECT asignatura
DB --> RepoAsig : resultado
RepoAsig --> Service : Optional<Asignatura>
deactivate RepoAsig

Service -> RepoAsig : save(asignaturaActualizada)
activate RepoAsig
RepoAsig -> DB : UPDATE asignatura
DB --> RepoAsig : ok
RepoAsig --> Service : asignatura
deactivate RepoAsig

Service --> Controller : void
deactivate Service

Controller --> FE : 200 OK
deactivate Controller

FE --> Actor : Muestra asignatura actualizada
deactivate FE

@enduml
