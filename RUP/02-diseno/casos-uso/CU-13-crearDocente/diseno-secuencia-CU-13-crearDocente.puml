@startuml secuencia-cu13-crear-docente
title Diagrama de Secuencia - Crear Docente

actor "Docente" as Actor
participant "Frontend\n(React)" as FE
participant "ControladorProfesor" as Controller
participant "ServicioProfesor" as Service
participant "RepositorioProfesor" as RepoProfesor
database "Base de Datos\n(PostgreSQL)" as DB

Actor -> FE : Introduce datos del nuevo docente
activate FE

FE -> Controller : POST /api/profesores (DTO_Profesor)
activate Controller

Controller -> Service : crearOActualizar(dto)
activate Service

Service -> RepoProfesor : findByDni(dni)
activate RepoProfesor
RepoProfesor -> DB : SELECT profesor
DB --> RepoProfesor : null
RepoProfesor --> Service : Optional.empty()
deactivate RepoProfesor

Service -> RepoProfesor : save(nuevoProfesor)
activate RepoProfesor
RepoProfesor -> DB : INSERT profesor
DB --> RepoProfesor : ok
RepoProfesor --> Service : profesor
deactivate RepoProfesor

Service --> Controller : void
deactivate Service

Controller --> FE : 200 OK
deactivate Controller

FE --> Actor : Muestra docente creado en tabla
deactivate FE

@enduml
