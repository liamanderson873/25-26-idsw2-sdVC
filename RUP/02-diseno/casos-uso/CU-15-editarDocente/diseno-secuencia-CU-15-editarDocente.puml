@startuml secuencia-cu15-editar-docente
title Diagrama de Secuencia - Editar Docente

actor "Administrador Institucional" as Actor
participant "Frontend\n(React)" as FE
participant "ControladorProfesor" as Controller
participant "ServicioProfesor" as Service
participant "RepositorioProfesor" as RepoProfesor
database "Base de Datos\n(PostgreSQL)" as DB

Actor -> FE : Modifica datos del docente
activate FE

FE -> Controller : POST /api/profesores (DTO_Profesor con DNI existente)
activate Controller

Controller -> Service : crearOActualizar(dto)
activate Service

Service -> RepoProfesor : findByDni(dni)
activate RepoProfesor
RepoProfesor -> DB : SELECT profesor
DB --> RepoProfesor : resultado
RepoProfesor --> Service : Optional<Profesor>
deactivate RepoProfesor

Service -> RepoProfesor : save(profesorActualizado)
activate RepoProfesor
RepoProfesor -> DB : UPDATE profesor
DB --> RepoProfesor : ok
RepoProfesor --> Service : profesor
deactivate RepoProfesor

Service --> Controller : void
deactivate Service

Controller --> FE : 200 OK
deactivate Controller

FE --> Actor : Muestra docente actualizado
deactivate FE

@enduml
