@startuml secuencia-cu28-eliminar-alumno
title Diagrama de Secuencia - Eliminar Alumno

actor "Docente" as Actor
participant "Frontend\n(React)" as FE
participant "ControladorAlumno" as Controller
participant "ServicioAlumno" as Service
participant "RepositorioAlumno" as RepoAlumno
database "Base de Datos\n(PostgreSQL)" as DB

Actor -> FE : Pulsa "Eliminar" en el alumno
activate FE

FE -> Controller : DELETE /api/alumnos/{id}
activate Controller

Controller -> Service : eliminar(id)
activate Service

Service -> RepoAlumno : existsById(id)
activate RepoAlumno
RepoAlumno -> DB : SELECT EXISTS
DB --> RepoAlumno : true/false
RepoAlumno --> Service : boolean
deactivate RepoAlumno

alt Alumno existe
    Service -> RepoAlumno : deleteById(id)
    activate RepoAlumno
    RepoAlumno -> DB : DELETE FROM alumnos
    DB --> RepoAlumno : ok
    RepoAlumno --> Service : ok
    deactivate RepoAlumno

    Service --> Controller : void
    deactivate Service

    Controller --> FE : 200 OK
    deactivate Controller

    FE --> Actor : Elimina la fila de la tabla
    deactivate FE
else Alumno no existe
    Service --> Controller : throw RuntimeException
    Controller --> FE : 400 Bad Request
    FE --> Actor : Muestra error
end

@enduml
