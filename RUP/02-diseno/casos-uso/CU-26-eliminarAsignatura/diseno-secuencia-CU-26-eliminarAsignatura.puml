@startuml secuencia-cu26-eliminar-asignatura
title Diagrama de Secuencia - Eliminar Asignatura

actor "Docente" as Actor
participant "Frontend\n(React)" as FE
participant "ControladorAsignatura" as Controller
participant "ServicioAsignatura" as Service
participant "RepositorioAsignatura" as RepoAsig
database "Base de Datos\n(PostgreSQL)" as DB

Actor -> FE : Pulsa "Eliminar" en la asignatura
activate FE

FE -> Controller : DELETE /api/asignaturas/{id}
activate Controller

Controller -> Service : eliminar(id)
activate Service

Service -> RepoAsig : existsById(id)
activate RepoAsig
RepoAsig -> DB : SELECT EXISTS
DB --> RepoAsig : true/false
RepoAsig --> Service : boolean
deactivate RepoAsig

alt Asignatura existe
    Service -> RepoAsig : deleteById(id)
    activate RepoAsig
    RepoAsig -> DB : DELETE FROM asignaturas
    DB --> RepoAsig : ok
    RepoAsig --> Service : ok
    deactivate RepoAsig

    Service --> Controller : void
    deactivate Service

    Controller --> FE : 200 OK
    deactivate Controller

    FE --> Actor : Elimina la fila de la tabla
    deactivate FE
else Asignatura no existe
    Service --> Controller : throw RuntimeException
    Controller --> FE : 400 Bad Request
    FE --> Actor : Muestra error
end

@enduml
