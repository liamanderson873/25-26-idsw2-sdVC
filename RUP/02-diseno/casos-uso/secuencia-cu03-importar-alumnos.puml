@startuml secuencia-cu03-importar-alumnos
skinparam style strictuml
skinparam sequenceMessageAlign center

actor Docente
participant "ControladorAlumno" as Boundary <<Boundary>>
participant "ServicioAlumno" as Control <<Control>>
participant "RepositorioGrado" as RepoGrado <<Entity>>
participant "RepositorioAlumno" as RepoAlumno <<Entity>>
database "PostgreSQL" as DB

Docente -> Boundary : POST /api/alumnos/importar (List<DTO_Alumno>)
activate Boundary

Boundary -> Control : importarAlumnos(listaDto)
activate Control

loop por cada DTO_Alumno
    Control -> RepoGrado : findByCodigo(codigoGrado)
    activate RepoGrado
    RepoGrado -> DB : SELECT grado
    DB --> RepoGrado : resultado
    RepoGrado --> Control : Optional<Grado>
    deactivate RepoGrado

    alt Grado no existe
        Control --> Boundary : throw RuntimeException("Grado no existe")
        Boundary --> Docente : 400 Bad Request (Error descriptivo)
    else Grado existe
        Control -> RepoAlumno : findByDni(dni)
        activate RepoAlumno
        RepoAlumno -> DB : SELECT alumno
        DB --> RepoAlumno : resultado
        RepoAlumno --> Control : Optional<Alumno>
        deactivate RepoAlumno

        Control -> Control : mapearDatos(alumno, dto, grado)
        
        Control -> RepoAlumno : save(alumno)
        activate RepoAlumno
        RepoAlumno -> DB : INSERT/UPDATE (UPSERT)
        DB --> RepoAlumno : ok
        RepoAlumno --> Control : alumnoGuardado
        deactivate RepoAlumno
    end
end

Control --> Boundary : void
deactivate Control

Boundary --> Docente : 200 OK (Procesado correctamente)
deactivate Boundary

@enduml
