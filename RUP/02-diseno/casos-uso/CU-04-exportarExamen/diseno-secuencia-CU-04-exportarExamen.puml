@startuml secuencia-cu04-exportar-examen
title Diagrama de Secuencia - Exportar Examen (Configuración Global)

actor "Docente" as Actor
participant "Frontend\n(React)" as FE
participant "ControladorExamen" as Controller
participant "ServicioExamen" as Service
participant "RepositorioExamen" as RepoExamen
participant "RepositorioExamenAlumno" as RepoExAl
database "Base de Datos\n(PostgreSQL)" as DB

Actor -> FE : Pulsa "Exportar Examen"
activate FE

FE -> Controller : GET /api/examenes/{id}/exportar
activate Controller

Controller -> Service : exportarExamen(examenId)
activate Service

Service -> RepoExamen : findById(examenId)
activate RepoExamen
RepoExamen -> DB : SELECT examen + preguntas + respuestas
DB --> RepoExamen : datos_completos
RepoExamen --> Service : examen
deactivate RepoExamen

Service -> RepoExAl : findAll() (filtrado por examenId)
activate RepoExAl
RepoExAl -> DB : SELECT examen_alumnos + alumnos
DB --> RepoExAl : lista_ejemplares
RepoExAl --> Service : ejemplares
deactivate RepoExAl

Service -> Service : mapearADtoExportacion(examen, ejemplares)
note right: Construye JSON con preguntas\ny claves SHA-256 de alumnos

Service --> Controller : DTO_ExportarExamen
deactivate Service

Controller --> FE : 200 OK (JSON del Examen)
deactivate Controller

FE --> Actor : Descarga fichero JSON
deactivate FE

@enduml
