@startuml secuencia-cu04-exportar-examen
skinparam style strictuml
skinparam sequenceMessageAlign center

actor Docente
participant "ControladorExamen" as Boundary <<Boundary>>
participant "ServicioExamen" as Control <<Control>>
participant "RepositorioExamen" as RepoExamen <<Entity>>
participant "RepositorioExamenAlumno" as RepoExAl <<Entity>>
database "PostgreSQL" as DB

Docente -> Boundary : GET /api/examenes/{id}/exportar
activate Boundary

Boundary -> Control : exportarExamen(examenId)
activate Control

Control -> RepoExamen : findById(examenId)
activate RepoExamen
RepoExamen -> DB : SELECT examen + preguntas + respuestas
DB --> RepoExamen : datos_completos
RepoExamen --> Control : examen
deactivate RepoExamen

Control -> RepoExAl : findAll() (filtrado por examenId)
activate RepoExAl
RepoExAl -> DB : SELECT examen_alumnos + alumnos
DB --> RepoExAl : lista_ejemplares
RepoExAl --> Control : ejemplares
deactivate RepoExAl

Control -> Control : mapearADtoExportacion(examen, ejemplares)
note right: Se construye el JSON final\ncon preguntas y claves SHA-256

Control --> Boundary : DTO_ExportarExamen
deactivate Control

Boundary --> Docente : 200 OK (JSON del Examen)
deactivate Boundary

@enduml
