@startuml secuencia-cu10-crear-pregunta
title Diagrama de Secuencia - Crear Pregunta

actor "Docente" as Actor
participant "Frontend\n(React)" as FE
participant "ControladorPregunta" as Controller
participant "ServicioPregunta" as Service
participant "RepositorioTema" as RepoTema
participant "RepositorioPregunta" as RepoPreg
participant "RepositorioRespuesta" as RepoResp
database "Base de Datos\n(PostgreSQL)" as DB

Actor -> FE : Introduce datos de la pregunta y respuestas
activate FE

FE -> Controller : POST /api/preguntas (DTO_Pregunta)
activate Controller

Controller -> Service : guardarIndividual(dto)
activate Service

Service -> RepoTema : findById(temaId)
activate RepoTema
RepoTema -> DB : SELECT tema
DB --> RepoTema : tema
RepoTema --> Service : Optional<Tema>
deactivate RepoTema

Service -> RepoPreg : save(pregunta)
activate RepoPreg
RepoPreg -> DB : INSERT pregunta
DB --> RepoPreg : ok
RepoPreg --> Service : preguntaGuardada
deactivate RepoPreg

loop por cada DTO_Respuesta
    Service -> RepoResp : save(respuesta)
    activate RepoResp
    RepoResp -> DB : INSERT respuesta
    DB --> RepoResp : ok
    RepoResp --> Service : ok
    deactivate RepoResp
end

Service --> Controller : void
deactivate Service

Controller --> FE : 200 OK
deactivate Controller

FE --> Actor : Muestra pregunta creada en batería
deactivate FE

@enduml
