@startuml secuencia-cu16-editar-alumno
skinparam style strictuml
skinparam sequenceMessageAlign center

actor Docente
participant "ControladorAlumno" as Boundary <<Boundary>>
participant "ServicioAlumno" as Control <<Control>>
participant "RepositorioGrado" as RepoGrado <<Entity>>
participant "RepositorioAlumno" as RepoAlumno <<Entity>>
database "PostgreSQL" as DB

Docente -> Boundary : POST /api/alumnos (DTO_Alumno con ID)
activate Boundary

Boundary -> Control : guardarIndividual(dto)
activate Control

Control -> RepoGrado : findByCodigo(codigoGrado)
activate RepoGrado
RepoGrado -> DB : SELECT grado
DB --> RepoGrado : resultado
RepoGrado --> Control : Optional<Grado>
deactivate RepoGrado

Control -> RepoAlumno : findById(id)
activate RepoAlumno
RepoAlumno -> DB : SELECT alumno
DB --> RepoAlumno : resultado
RepoAlumno --> Control : Optional<Alumno>
deactivate RepoAlumno

Control -> RepoAlumno : save(alumnoActualizado)
activate RepoAlumno
RepoAlumno -> DB : UPDATE alumno
DB --> RepoAlumno : ok
RepoAlumno --> Control : alumno
deactivate RepoAlumno

Control --> Boundary : void
deactivate Control

Boundary --> Docente : 200 OK
deactivate Boundary

@enduml
