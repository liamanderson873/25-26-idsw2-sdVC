@startuml
title Diagrama de Entidad-Relación - Jorgestor (Jerarquía Evolucionada)

' Forzar disposición vertical de arriba a abajo
top to bottom direction
skinparam linetype ortho

' --- NIVEL 1: CIMIENTOS (LOS MAESTROS) ---
class Grado {
  -id: Long
  -título: String
  -código: String
}

class Profesor {
  -id: Long
  -nombre: String
  -apellidos: String
  -DNI: String
  -email: String
}

' --- NIVEL 2: DEFINICIÓN ACADÉMICA ---
class Asignatura {
  -id: Long
  -título: String
  -código: String
  -cursoAcademico: String
  -cursoSugerido: Integer
}

' --- NIVEL 3: RECURSOS (LA BATERÍA) ---
class Tema {
  -id: Long
  -nombre: String
}

class Pregunta {
  -id: Long
  -enunciado: String
  -dificultad: DificultadPregunta
}

class Respuesta {
  -id: Long
  -contenido: String
  -esCorrecta: Boolean
  -índice: Integer
}

' --- NIVEL 4: OPERACIÓN (EL MODELO) ---
class Examen {
  -id: Long
  -fecha: LocalDate
  -evaluación: EvaluaciónExamen
  -esPersonalizado: Boolean
}

' --- NIVEL 5: EJECUCIÓN (EL EJEMPLAR) ---
class Alumno {
  -id: Long
  -nombre: String
  -apellidos: String
  -DNI: String
  -curso: Integer
}

class ExamenAlumno {
  -id: Long
  -claveCorreccion: String (SHA-256)
  -notaFinal: Double
  -estado: EstadoExamen
}

class ExamenAlumnoMarca {
  -id: Long
  -índiceMarcado: Integer
}

' --- RELACIONES JERÁRQUICAS ---

' Nivel 1 -> Nivel 2
Profesor "1" -- "*" Asignatura : imparte
Asignatura "*" -- "*" Grado : se imparte en

' Nivel 2 -> Nivel 3
Asignatura "1" -- "*" Tema : contiene
Tema "1" -- "*" Pregunta : tiene
Pregunta "1" -- "*" Respuesta : contiene

' Nivel 2 -> Nivel 4
Examen "*" -- "1" Asignatura : basado en
Examen "1" -- "*" Pregunta : selecciona

' Nivel 4 -> Nivel 5 (Instanciación)
Examen "1" -- "*" ExamenAlumno : genera
Alumno "1" -- "*" ExamenAlumno : posee
Alumno "*" -- "*" Asignatura : matriculado
Alumno "*" -- "1" Grado : pertenece

' Nivel 5 (Auditoría)
ExamenAlumno "1" *-- "*" ExamenAlumnoMarca : registra
ExamenAlumnoMarca "*" -- "1" Pregunta : marcada
ExamenAlumnoMarca "*" -- "1" Respuesta : elegida

@enduml
