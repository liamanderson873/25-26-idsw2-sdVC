@startuml
title Diagrama de Entidad-Relación - Jorgestor (Implementación Final)

class Examen{
 - id: Long
 - fecha: LocalDate
 - evaluación: EvaluaciónExamen
 - esPersonalizado: Boolean
}

class Asignatura{
 - id: Long
 - título: String
 - código: String
 - curso académico: String
 - curso sugerido: Integer
}

class Pregunta{
 - id: Long
 - enunciado: String
 - dificultad: DificultadPregunta
}

class Grado{
 - id: Long
 - título: String
 - código: String
}

class Profesor{
 - id: Long
 - nombre: String
 - apellidos: String
 - DNI: String
 - email: String
}

class Alumno{
 - id: Long
 - nombre: String
 - apellidos: String
 - DNI: String
 - curso: Integer
}

enum EvaluaciónExamen{
 PARCIAL_1
 PARCIAL_2
 PARCIAL_3
 FINAL
 EXTRAORDINARIO
}

enum DificultadPregunta{
 FACIL
 MEDIO
 DIFICIL
}

class Respuesta{
 - id: Long
 - contenido: String
 - esCorrecta: Boolean
 - índice: Integer
}

class Tema {
 - id: Long
 - nombre: String
}

class ExamenAlumno {
 - id: Long
 - claveCorreccion: String (SHA-256)
 - notaFinal: Double
 - estado: EstadoExamen
}

class ExamenAlumnoMarca {
 - id: Long
 - índiceMarcado: Integer
}

' Relaciones exactas al original pero extendidas
Respuesta "*" -u-o "1" Pregunta : contiene
Pregunta ..> DificultadPregunta
Pregunta "*" -u-o "1" Examen : contiene
Examen ..> EvaluaciónExamen
Examen "*" -- "1" Asignatura : tiene
Profesor "1" -r- "*" Asignatura : imparte
Asignatura "*" --> "*" Grado : pertenece
Alumno "*" -u-o "*" ExamenAlumno : realiza
Examen "1" -d- "*" ExamenAlumno : tiene
Alumno "*" -- "*" Asignatura : se imparte
Alumno "*" -- "1" Grado : se cursa
Pregunta "*" ..> "1" Tema : pertenece
Tema "*" -- "1" Asignatura : tiene

' Auditoría (Nuevo pero integrado en la línea)
ExamenAlumno "1" *-- "*" ExamenAlumnoMarca : registra
ExamenAlumnoMarca "*" -- "1" Pregunta
ExamenAlumnoMarca "*" -- "1" Respuesta

@enduml
