@startuml
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor white
  BorderColor #475569
  HeaderBackgroundColor #e2e8f0
  FontName Arial
  FontSize 11
}
skinparam enum {
  BackgroundColor #fef9c3
  BorderColor #ca8a04
  FontName Arial
  FontSize 10
}
skinparam note {
  BackgroundColor #f0f9ff
  BorderColor #0ea5e9
  FontSize 9
}
hide empty members
left to right direction

' ══════════════════════════════════════════════
' ENUMS
' ══════════════════════════════════════════════

enum Rol {
  DOCENTE
  ADMINISTRADOR_INSTITUCIONAL
}

enum Dificultad {
  BAJA
  MEDIA
  ALTA
}

enum TipoEvaluacion {
  PARCIAL_1
  PARCIAL_2
  PARCIAL_3
  FINAL
  EXTRAORDINARIO
}

enum EstadoExamen {
  PENDIENTE
  ASIGNADO
  PENDIENTE_CALIFICACION
  CORREGIDO
}

' ══════════════════════════════════════════════
' ENTIDADES
' ══════════════════════════════════════════════

class Usuario <<Entity>> {
  + id : Long
  + username : String
  # password : String
  + nombre : String
  + rol : Rol
}

class Profesor <<Entity>> {
  + id : Long
  + dni : String
  + nombre : String
  + apellidos : String
  + email : String
}

class Grado <<Entity>> {
  + id : Long
  + codigo : String
  + nombre : String
}

class Alumno <<Entity>> {
  + id : Long
  + dni : String
  + nombre : String
  + apellidos : String
  + curso : Integer
}

class Asignatura <<Entity>> {
  + id : Long
  + nombre : String
  + codigo : String
  + cursoAcademico : String
  + cursoSugerido : Integer
}

class Tema <<Entity>> {
  + id : Long
  + nombre : String
}

class Pregunta <<Entity>> {
  + id : Long
  + enunciado : String
  + dificultad : Dificultad
  + habilitada : Boolean
}

class Respuesta <<Entity>> {
  + id : Long
  + contenido : String
  + indice : Integer
  + esCorrecta : Boolean
}

class Examen <<Entity>> {
  + id : Long
  + tipoEvaluacion : TipoEvaluacion
  + fechaExamen : LocalDate
  + esPersonalizado : Boolean
}

class ExamenAlumno <<Entity>> {
  + id : Long
  + claveCorreccion : String
  + notaSugerida : Double
  + notaFinal : Double
  + estado : EstadoExamen
}

class ExamenAlumnoMarca <<Entity>> {
  + id : Long
  + indiceMarcado : Integer
}

' ══════════════════════════════════════════════
' RELACIONES
' ══════════════════════════════════════════════

' Auth
Usuario       ..>  Rol

' Estructura académica
Profesor      "1"  --  "*"  Asignatura  : imparte
Alumno        "*"  -->  "1"  Grado      : cursa en
Asignatura    "*"  --  "*"  Grado       : asignatura_grados\n<<tabla intermedia>>
Alumno        "*"  --  "*"  Asignatura  : matriculas\n<<tabla intermedia>>

' Contenido
Asignatura    "1"  --  "*"  Tema        : tiene
Pregunta      "*"  -->  "1"  Tema        : sobre
Pregunta      ..>  Dificultad
Respuesta     "*"  -->  "1"  Pregunta    : opción de

' Examen
Examen        ..>  TipoEvaluacion
Examen        "*"  -->  "1"  Asignatura  : de
Examen        "*"  --  "*"  Pregunta     : examen_preguntas\n<<tabla intermedia>>

' Ejemplar
ExamenAlumno  ..>  EstadoExamen
ExamenAlumno  "*"  -->  "1"  Examen      : ejemplar de
ExamenAlumno  "*"  -->  "1"  Alumno      : asignado a

' Auditoría
ExamenAlumnoMarca  "*"  -->  "1"    ExamenAlumno  : auditoría de
ExamenAlumnoMarca  "*"  -->  "1"    Pregunta      : marcada
ExamenAlumnoMarca  "*"  -->  "0..1" Respuesta     : elegida\n(null = en blanco)

@enduml
