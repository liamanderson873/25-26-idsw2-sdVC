@startuml
title Diagrama de Entidad-Relación - Jorgestor (Implementación Final)

' Definición de la disposición visual para que sea idéntica a la original
'pero incluyendo los campos técnicos reales.

class Examen{
 -id: Long
 -evaluación: EvaluaciónExamen
 -clave corrección: String
 -fecha: LocalDate
 -esPersonalizado: Boolean
}

class Asignatura{
 -id: Long
 -título: String
 -código: String
 -curso académico: String
 -curso sugerido: Integer
}

class Pregunta{
 -id: Long
 -asignatura: Asignatura
 -enunciado: String
 -tema: Tema
 -dificultad: DificultadPregunta
}

class BateriaDePreguntas{
}

class Grado{
 -id: Long
 -título: String
 -código: String
}

class Profesor{
 -id: Long
 -nombre: String
 -apellidos: String
 -DNI: String
}

class Alumno{
 -id: Long
 -nombre: String
 -apellidos: String
 -DNI: String
 -curso: Integer
}

enum EvaluaciónExamen{
 -Parcial 1
 -Parcial 2
 -Parcial 3
 -Examen final
 -Examen extraordinario
}

enum DificultadPregunta{
 -facil
 -medio
 -dificil
}

class Respuesta{
 -id: Long
 -opción: String
 -esCorrecta: Boolean
 -índice: Integer
}

class Tema{
 -id: Long
 -nombre: String
}

class ExamenAlumno {
 -id: Long
 -claveCorreccion: String (SHA-256)
 -notaFinal: Double
 -estado: EstadoExamen
}

class ExamenAlumnoMarca {
 -id: Long
 -indiceMarcado: Integer
}

' Relaciones del diagrama original (Baseline)
Respuesta -u-* Pregunta
Pregunta ..> DificultadPregunta
Pregunta -u-o Examen : contiene
Pregunta -u-* BateriaDePreguntas : contiene
Examen ..> EvaluaciónExamen
BateriaDePreguntas -u-* Asignatura : tiene
Examen -u-* Asignatura : tiene
Profesor o-r- Asignatura : tiene
Asignatura --> Grado : pertenece
Alumno -u-o Examen : realiza
Alumno -u-* Asignatura : se imparte
Alumno -u-* Grado : se cursa
Pregunta ..> Tema

' Extensiones de la Implementación (As-Built) conectadas sin romper la jerarquía original
Examen "1" -- "*" ExamenAlumno : genera
Alumno "1" -- "*" ExamenAlumno : posee
ExamenAlumno "1" *-- "*" ExamenAlumnoMarca : auditoría
ExamenAlumnoMarca "*" -- "1" Pregunta : marcada
ExamenAlumnoMarca "*" -- "1" Respuesta : elegida
Tema "*" -- "1" Asignatura : pertenece

@enduml
