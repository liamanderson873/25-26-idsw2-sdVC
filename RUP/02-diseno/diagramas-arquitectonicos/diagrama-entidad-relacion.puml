@startuml
title Diagrama de Entidad-Relación - Jorgestor (Jerarquía Final)

' Configuración de layout vertical
top to bottom direction
skinparam linetype ortho

' --- NIVEL 1: LAS DEFINICIONES (EL MODELO) ---
package "Capa de Definición (Modelo)" {
    class Examen {
        +id: Long
        +fecha: LocalDate
        +tipoEvaluacion: EvaluaciónExamen
        +esPersonalizado: Boolean
    }

    class Asignatura {
        +id: Long
        +título: String
        +código: String
        +cursoAcademico: String
        +cursoSugerido: Integer
    }

    class Grado {
        +id: Long
        +título: String
        +código: String
    }

    class Profesor {
        +id: Long
        +nombre: String
        +apellidos: String
        +DNI: String
    }
}

' --- NIVEL 2: EL CONTENIDO (LA ESTRUCTURA) ---
package "Capa de Contenido" {
    class Tema {
        +id: Long
        +nombre: String
    }

    class Pregunta {
        +id: Long
        +enunciado: String
        +dificultad: DificultadPregunta
    }

    class Respuesta {
        +id: Long
        +contenido: String
        +esCorrecta: Boolean
        +indice: Integer
    }
}

' --- NIVEL 3: LAS INSTANCIAS (EL EJEMPLAR) ---
package "Capa de Ejecución (Ejemplar)" {
    class Alumno {
        +id: Long
        +nombre: String
        +apellidos: String
        +DNI: String
        +curso: Integer
    }

    class ExamenAlumno {
        +id: Long
        +claveCorreccion: String (SHA-256)
        +notaFinal: Double
        +estado: EstadoExamen
    }

    class ExamenAlumnoMarca {
        +id: Long
        +indiceMarcado: Integer
    }
}

' --- RELACIONES JERÁRQUICAS ---

' Nivel 1 -> Nivel 1
Profesor "1" -- "*" Asignatura : imparte
Asignatura "*" -- "*" Grado : se imparte en

' Nivel 1 -> Nivel 2
Asignatura "1" -- "*" Tema : contiene
Tema "1" -- "*" Pregunta : tiene
Pregunta "1" -- "*" Respuesta : contiene

' Nivel 1 -> Nivel 2
Examen "*" -- "1" Asignatura : basado en
Examen "1" -- "*" Pregunta : selecciona

' Nivel 1 & 2 -> Nivel 3 (Instanciación)
Examen "1" -- "*" ExamenAlumno : genera ejemplares
Alumno "1" -- "*" ExamenAlumno : realiza
Alumno "*" -- "*" Asignatura : matriculado en
Alumno "*" -- "1" Grado : pertenece

' Nivel 3 -> Nivel 3 (Auditoría)
ExamenAlumno "1" *-- "*" ExamenAlumnoMarca : registra
ExamenAlumnoMarca "*" -- "1" Pregunta : pregunta marcada
ExamenAlumnoMarca "*" -- "1" Respuesta : opción elegida

@enduml
