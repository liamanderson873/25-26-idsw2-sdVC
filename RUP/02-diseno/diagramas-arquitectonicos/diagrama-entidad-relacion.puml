@startuml
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam class {
  BackgroundColor white
  BorderColor #475569
  HeaderBackgroundColor #e2e8f0
  FontName Arial
  FontSize 12
}
skinparam enum {
  BackgroundColor #fef9c3
  BorderColor #ca8a04
  FontName Arial
  FontSize 11
}
skinparam note {
  BackgroundColor #f0f9ff
  BorderColor #0ea5e9
  FontSize 10
}
hide empty members

top to bottom direction

' ══════════════════════════════════════════════
' ENUMERACIONES
' ══════════════════════════════════════════════

enum Rol {
  DOCENTE
  ADMINISTRADOR_INSTITUCIONAL
}

enum TipoEvaluacion {
  PARCIAL_1
  PARCIAL_2
  PARCIAL_3
  FINAL
  EXTRAORDINARIO
}

enum Dificultad {
  BAJA
  MEDIA
  ALTA
}

enum EstadoExamen {
  PENDIENTE
  ASIGNADO
  REALIZADO
  ENTREGADO
  PENDIENTE_CALIFICACION
  CORREGIDO
}

' ══════════════════════════════════════════════
' CAPA 1 — USUARIOS Y AUTENTICACIÓN
' ══════════════════════════════════════════════

together {
  class Usuario <<Entity>> {
    + id : Long
    + username : String
    # password : String
    + nombre : String
    + rol : Rol
  }

  class Profesor <<Entity>> {
    + id : Long
    + dni : String
    + nombre : String
    + apellidos : String
    + email : String
    + usuario : String
    # password : String
  }
}

' ══════════════════════════════════════════════
' CAPA 2 — ESTRUCTURA ACADÉMICA
' ══════════════════════════════════════════════

together {
  class Grado <<Entity>> {
    + id : Long
    + codigo : String
    + nombre : String
  }

  class Asignatura <<Entity>> {
    + id : Long
    + nombre : String
    + codigo : String
    + cursoAcademico : String
    + cursoSugerido : Integer
  }

  class Alumno <<Entity>> {
    + id : Long
    + dni : String
    + nombre : String
    + apellidos : String
    + curso : Integer
  }
}

' ══════════════════════════════════════════════
' CAPA 3 — CONTENIDO (PREGUNTAS)
' ══════════════════════════════════════════════

together {
  class Tema <<Entity>> {
    + id : Long
    + nombre : String
  }

  class Pregunta <<Entity>> {
    + id : Long
    + enunciado : String
    + dificultad : Dificultad
    + habilitada : Boolean
  }

  class Respuesta <<Entity>> {
    + id : Long
    + contenido : String
    + indice : Integer
    + esCorrecta : Boolean
  }
}

' ══════════════════════════════════════════════
' CAPA 4 — EXÁMENES
' ══════════════════════════════════════════════

class Examen <<Entity>> {
  + id : Long
  + tipoEvaluacion : TipoEvaluacion
  + fechaExamen : LocalDate
  + esPersonalizado : Boolean
}

' ══════════════════════════════════════════════
' CAPA 5 — EJEMPLARES (EXAMEN POR ALUMNO)
' ══════════════════════════════════════════════

class ExamenAlumno <<Entity>> {
  + id : Long
  + claveCorreccion : String
  + notaSugerida : Double
  + notaFinal : Double
  + estado : EstadoExamen
}

' ══════════════════════════════════════════════
' CAPA 6 — AUDITORÍA (MARCAS)
' ══════════════════════════════════════════════

class ExamenAlumnoMarca <<Entity>> {
  + id : Long
  + indiceMarcado : Integer
}

' ══════════════════════════════════════════════
' RELACIONES
' ══════════════════════════════════════════════

' Auth
Usuario       ..>  Rol

' Estructura académica
Profesor      "1"  -d-o  "*"  Asignatura       : imparte
Asignatura    "*"  -d--  "*"  Grado            : asignatura_grados
note on link
  tabla intermedia
end note
Alumno        "*"  -u->  "1"  Grado            : cursa en
Alumno        "*"  -u--  "*"  Asignatura       : matriculas
note on link
  tabla intermedia
end note

' Contenido
Tema          "*"  -u->  "1"  Asignatura       : pertenece a
Pregunta      ..>  Dificultad
Pregunta      "*"  -u->  "1"  Tema             : sobre
Respuesta     "*"  -u->  "1"  Pregunta         : opciones de

' Examen
Examen        ..>  TipoEvaluacion
Examen        "*"  -u->  "1"  Asignatura       : de
Examen        "*"  -u--  "*"  Pregunta         : examen_preguntas
note on link
  tabla intermedia
end note

' Ejemplar
ExamenAlumno  ..>  EstadoExamen
ExamenAlumno  "*"  -u->  "1"  Examen           : ejemplar de
ExamenAlumno  "*"  -u->  "1"  Alumno           : asignado a

' Auditoría
ExamenAlumnoMarca  "*"  -u->  "1"      ExamenAlumno  : auditoria de
ExamenAlumnoMarca  "*"  -r->  "1"      Pregunta      : pregunta marcada
ExamenAlumnoMarca  "*"  -r->  "0..1"   Respuesta     : respuesta elegida\n(null = en blanco)

@enduml
