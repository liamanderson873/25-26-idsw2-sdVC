@startuml
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor white
  BorderColor #475569
  HeaderBackgroundColor #e2e8f0
  FontName Arial
  FontSize 11
}
skinparam enum {
  BackgroundColor #fef9c3
  BorderColor #ca8a04
  FontName Arial
  FontSize 10
}
hide empty members

' ── Nivel 1: Entidad central ─────────────────────
class Asignatura <<Entity>> {
  + id : Long
  + nombre : String
  + codigo : String
  + cursoAcademico : String
  + cursoSugerido : Integer
}

' ── Nivel 2: Entidades vinculadas directamente ───
together {
  class Grado <<Entity>> {
    + id : Long
    + codigo : String
    + nombre : String
  }
  class Alumno <<Entity>> {
    + id : Long
    + dni : String
    + nombre : String
    + apellidos : String
    + curso : Integer
  }
  class Profesor <<Entity>> {
    + id : Long
    + dni : String
    + nombre : String
    + apellidos : String
    + email : String
  }
  class Tema <<Entity>> {
    + id : Long
    + nombre : String
  }
}

' ── Nivel 3: Contenido y generación ─────────────
together {
  class Pregunta <<Entity>> {
    + id : Long
    + enunciado : String
    + dificultad : Dificultad
    + habilitada : Boolean
  }
  enum Dificultad {
    BAJA
    MEDIA
    ALTA
  }
  class Examen <<Entity>> {
    + id : Long
    + tipoEvaluacion : TipoEvaluacion
    + fechaExamen : LocalDate
    + esPersonalizado : Boolean
  }
  enum TipoEvaluacion {
    PARCIAL_1
    PARCIAL_2
    PARCIAL_3
    FINAL
    EXTRAORDINARIO
  }
}

' ── Nivel 4: Ejemplar y respuestas ──────────────
together {
  class Respuesta <<Entity>> {
    + id : Long
    + contenido : String
    + indice : Integer
    + esCorrecta : Boolean
  }
  class ExamenAlumno <<Entity>> {
    + id : Long
    + claveCorreccion : String
    + notaSugerida : Double
    + notaFinal : Double
    + estado : EstadoExamen
  }
  enum EstadoExamen {
    PENDIENTE
    ASIGNADO
    PENDIENTE_CALIFICACION
    CORREGIDO
  }
}

' ── Nivel 5: Auditoría ───────────────────────────
class ExamenAlumnoMarca <<Entity>> {
  + id : Long
  + indiceMarcado : Integer
}

' ── Auth (independiente) ─────────────────────────
together {
  class Usuario <<Entity>> {
    + id : Long
    + username : String
    # password : String
    + nombre : String
    + rol : Rol
  }
  enum Rol {
    DOCENTE
    ADMINISTRADOR_INSTITUCIONAL
  }
}

' ══════════════════════════════════════════════
' RELACIONES
' ══════════════════════════════════════════════

' Auth
Usuario       ..>  Rol

' Asignatura como eje
Profesor      "1"  --  "*"  Asignatura    : imparte
Asignatura    "*"  --  "*"  Grado         : asignatura_grados\n<<tabla intermedia>>
Alumno        "*"  --  "*"  Asignatura    : matriculas\n<<tabla intermedia>>
Asignatura    "1"  --  "*"  Tema          : tiene

' Alumno → Grado
Alumno        "*"  -->  "1"  Grado        : cursa en

' Contenido
Pregunta      "*"  -->  "1"  Tema          : sobre
Pregunta      ..>  Dificultad
Respuesta     "*"  -->  "1"  Pregunta      : opción de

' Examen
Examen        ..>  TipoEvaluacion
Examen        "*"  -->  "1"  Asignatura    : de
Examen        "*"  --  "*"  Pregunta       : examen_preguntas\n<<tabla intermedia>>

' Ejemplar
ExamenAlumno  ..>  EstadoExamen
ExamenAlumno  "*"  -->  "1"  Examen        : ejemplar de
ExamenAlumno  "*"  -->  "1"  Alumno        : asignado a

' Auditoría
ExamenAlumnoMarca  "*"  -->  "1"    ExamenAlumno  : auditoría de
ExamenAlumnoMarca  "*"  -->  "1"    Pregunta      : marcada
ExamenAlumnoMarca  "*"  -->  "0..1" Respuesta     : elegida\n(null = en blanco)

@enduml
