@startuml
skinparam classAttributeIconSize 0
skinparam linetype ortho
hide empty members

' ─── Enumeraciones ───────────────────────────────────────────────

enum Rol {
  DOCENTE
  ADMINISTRADOR_INSTITUCIONAL
}

enum Dificultad {
  BAJA
  MEDIA
  ALTA
}

enum TipoEvaluacion {
  PARCIAL_1
  PARCIAL_2
  PARCIAL_3
  FINAL
  EXTRAORDINARIO
}

enum EstadoExamen {
  PENDIENTE
  ASIGNADO
  REALIZADO
  ENTREGADO
  PENDIENTE_CALIFICACION
  CORREGIDO
}

' ─── Entidades ───────────────────────────────────────────────────

class Usuario <<Entity>> {
  + id : Long
  + username : String
  # password : String
  + nombre : String
  + rol : Rol
}

class Profesor <<Entity>> {
  + id : Long
  + dni : String
  + nombre : String
  + apellidos : String
  + email : String
  + usuario : String
  # password : String
}

class Grado <<Entity>> {
  + id : Long
  + codigo : String
  + nombre : String
}

class Asignatura <<Entity>> {
  + id : Long
  + nombre : String
  + codigo : String
  + cursoAcademico : String
  + cursoSugerido : Integer
}

class Alumno <<Entity>> {
  + id : Long
  + dni : String
  + nombre : String
  + apellidos : String
  + curso : Integer
}

class Tema <<Entity>> {
  + id : Long
  + nombre : String
}

class Pregunta <<Entity>> {
  + id : Long
  + enunciado : String
  + dificultad : Dificultad
  + habilitada : Boolean
}

class Respuesta <<Entity>> {
  + id : Long
  + contenido : String
  + indice : Integer
  + esCorrecta : Boolean
}

class Examen <<Entity>> {
  + id : Long
  + tipoEvaluacion : TipoEvaluacion
  + fechaExamen : LocalDate
  + esPersonalizado : Boolean
}

class ExamenAlumno <<Entity>> {
  + id : Long
  + claveCorreccion : String
  + notaSugerida : Double
  + notaFinal : Double
  + estado : EstadoExamen
}

class ExamenAlumnoMarca <<Entity>> {
  + id : Long
  + indiceMarcado : Integer
}

' ─── Relaciones ──────────────────────────────────────────────────

Usuario      ..>  Rol

Profesor     "1"  o--  "*"    Asignatura      : imparte

Asignatura   "*"  --   "*"    Grado           : asignatura_grados
note on link: tabla intermedia

Alumno       "*"  -->  "1"    Grado           : cursa en
Alumno       "*"  --   "*"    Asignatura      : matriculas
note on link: tabla intermedia

Tema         "*"  -->  "1"    Asignatura      : pertenece a
Pregunta     ..>  Dificultad
Pregunta     "*"  -->  "1"    Tema            : sobre
Respuesta    "*"  -->  "1"    Pregunta        : opciones de

Examen       ..>  TipoEvaluacion
Examen       "*"  -->  "1"    Asignatura      : de
Examen       "*"  --   "*"    Pregunta        : examen_preguntas
note on link: tabla intermedia

ExamenAlumno ..>  EstadoExamen
ExamenAlumno "*"  -->  "1"    Examen          : ejemplar de
ExamenAlumno "*"  -->  "1"    Alumno          : asignado a

ExamenAlumnoMarca "*" -->  "1"      ExamenAlumno    : auditoria de
ExamenAlumnoMarca "*" -->  "1"      Pregunta        : pregunta marcada
ExamenAlumnoMarca "*" -->  "0..1"   Respuesta       : respuesta elegida

@enduml
