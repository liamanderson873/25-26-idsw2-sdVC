@startuml
!theme plain
skinparam Linetype ortho

entity "grados" as grados {
  * id : BIGINT <<generated>>
  --
  * nombre : VARCHAR(100)
  * codigo : VARCHAR(20) <<unique>>
}

entity "profesores" as profesores {
  * id : BIGINT <<generated>>
  --
  * dni : VARCHAR(9) <<unique>>
  * nombre : VARCHAR(50)
  * apellidos : VARCHAR(50)
  * email : VARCHAR(100)
}

entity "asignaturas" as asignaturas {
  * id : BIGINT <<generated>>
  --
  * nombre : VARCHAR(100)
  * codigo : VARCHAR(20) <<unique>>
  * curso_academico : VARCHAR(10)
  * profesor_id : BIGINT <<FK>>
}

entity "alumnos" as alumnos {
  * id : BIGINT <<generated>>
  --
  * dni : VARCHAR(9) <<unique>>
  * nombre : VARCHAR(50)
  * apellidos : VARCHAR(50)
  * grado_id : BIGINT <<FK>>
}

entity "asignaturas_alumnos" as asignaturas_alumnos {
  * asignatura_id : BIGINT <<FK>>
  * alumno_id : BIGINT <<FK>>
}

entity "temas" as temas {
  * id : BIGINT <<generated>>
  --
  * nombre : VARCHAR(100)
  * asignatura_id : BIGINT <<FK>>
}

entity "preguntas" as preguntas {
  * id : BIGINT <<generated>>
  --
  * enunciado : TEXT
  * dificultad : ENUM(FACIL, MEDIO, DIFICIL)
  * tema_id : BIGINT <<FK>>
}

entity "respuestas" as respuestas {
  * id : BIGINT <<generated>>
  --
  * texto : VARCHAR(255)
  * es_correcta : BOOLEAN
  * indice : INTEGER
  * pregunta_id : BIGINT <<FK>>
}

entity "examen_alumno_marcas" as examen_alumno_marcas {
  * id : BIGINT <<generated>>
  --
  * examen_alumno_id : BIGINT <<FK>>
  * pregunta_id : BIGINT <<FK>>
  * respuesta_id : BIGINT <<FK>>
  * indice_marcado : INTEGER
}

grados ||--o{ alumnos
profesores ||--o{ asignaturas
asignaturas ||--o{ temas
asignaturas ||--o{ examenes
temas ||--o{ preguntas
preguntas ||--o{ respuestas
examenes ||--o{ examen_preguntas
preguntas ||--o{ examen_preguntas
alumnos ||--o{ examen_alumnos
examenes ||--o{ examen_alumnos
examen_alumnos ||--o{ examen_alumno_marcas
preguntas ||--o{ examen_alumno_marcas
respuestas ||--o{ examen_alumno_marcas
asignaturas ||--o{ asignaturas_alumnos
alumnos ||--o{ asignaturas_alumnos

@enduml
